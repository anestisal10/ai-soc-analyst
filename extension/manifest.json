{
    "manifest_version": 3,
    "name": "AI SOC Phishing Analyzer",
    "version": "1.0.0",
    "description": "Analyze selected text for phishing using AI SOC Analyst.",
    "permissions": [
        "contextMenus",
        "activeTab",
        "scripting"
